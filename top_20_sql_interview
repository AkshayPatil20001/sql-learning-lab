-- 1. Second Highest salary

 # Approach 1: Using Limit with Offset
SELECT EmpName, Salary 
FROM Employee
ORDER BY Salary DESC
LIMIT 1 OFFSET 1;

# Approach 2: Using Dense Rank Windows Functioin
SELECT EmpName, Salary
FROM (
    SELECT EmpName, Salary,
           DENSE_RANK() OVER (ORDER BY Salary DESC) AS mk
    FROM Employee
) AS bc
WHERE mk = 2;


-- 2. Department wise highest Salary

 # Approach 1: Using Windows Function
 SELECT *
FROM (
    SELECT Department, EmpName, Salary,
           DENSE_RANK() OVER (PARTITION BY Department ORDER BY Salary DESC) AS rnk
    FROM Employee
) AS bc
WHERE rnk = 1;

 # Approach 2: Using group by
SELECT Department, MAX(Salary) AS HighestSalary
FROM Employee
GROUP BY Department;


-- 3. Display Alternate Records
-- #Approach 1:
SELECT EmpID, EmpName, Department, Salary
FROM (
    SELECT EmpID, EmpName, Department, Salary,
           ROW_NUMBER() OVER (ORDER BY EmpID) AS rn
    FROM Employee
) AS numbered
WHERE rn % 2 = 1;   -- odd rows (1st, 3rd, 5th...)

-- #Approach 2:
SELECT * 
FROM Employee
WHERE MOD(EmpID, 2) = 1;


-- 4. Display Duplicates of a columns
-- #Approach1: 
SELECT EmpName, COUNT(*)
FROM Employee
GROUP BY EmpName
HAVING COUNT(*) > 1;

-- #Approach2:
SELECT *
FROM Employee
WHERE EmpName IN (
    SELECT EmpName
    FROM Employee
    GROUP BY EmpName
    HAVING COUNT(*) > 1
);

-- 5.Pattern Matching
-- # 1. Select all employee names from the EMP table that start with the letter 'M'
SELECT EmpName
FROM EMP
WHERE EmpName LIKE 'M%';

-- # 2. Display employee names that end with the letter 'n'
SELECT EmpName
FROM EMP
WHERE EmpName LIKE '%n';

-- # 3. Find all employees who have the letter 'M' anywhere in their name
SELECT EmpName
FROM EMP
WHERE EmpName LIKE '%M%';

-- # 4. List all employee names that do not contain the letter 'M'
SELECT EmpName
FROM EMP
WHERE EmpName NOT LIKE '%M%';


-- 6.Pattern Questions
-- # 1. Display the names of all employees whose name contains exactly four letters
SELECT EmpName
FROM Employee
WHERE EmpName LIKE '____';

-- # 2. Display the names of employees whose name contains 'L' as the second letter and 'M' as the fourth letter
SELECT EmpName
FROM Employee
WHERE EmpName LIKE '_L_M%';

-- # 3. Display the employee names and hire dates for the employees who joined in the month of December
SELECT EmpName, HireDate
FROM Employee
WHERE MONTH(HireDate) = 12;

-- # 4. Display the names of employees whose name contains exactly two 'L's
SELECT EmpName
FROM Employee
WHERE EmpName LIKE '%L%L%'
  AND EmpName NOT LIKE '%L%L%L%';

-- # 5. Display the names of employees whose name starts with 'J' and ends with 'S'
SELECT EmpName
FROM Employee
WHERE EmpName LIKE 'J%S';


-- 7. Displaying the nth row in place of n add any row number which you want to display

WITH RankedEmployees AS (
    SELECT empid, empname, 
           ROW_NUMBER() OVER (ORDER BY empid) AS row_num 
    FROM employee
)
SELECT empid, empname, row_num
FROM RankedEmployees
WHERE row_num = 4;


-- 8. Union and Union ALL
-- # 1. Combine employee names from Employee and Manager tables,
--    remove duplicates, and indicate source
SELECT EmpName, 'Employee' AS Source
FROM Employee
UNION
SELECT ManagerName, 'Manager' AS Source
FROM Manager;

-- # 2. Merge sales records from OnlineSales and StoreSales tables
--    using UNION ALL, then calculate total revenue grouped by ProductID
SELECT ProductID, SUM(Revenue) AS TotalRevenue
FROM (
    SELECT ProductID, Revenue
    FROM OnlineSales
    UNION ALL
    SELECT ProductID, Revenue
    FROM StoreSales
) AS CombinedSales
GROUP BY ProductID;


-- 9. Display first and last row 

-- #Approach 1:
WITH first_last AS (
    SELECT 
        empid,
        empname,
        ROW_NUMBER() OVER(ORDER BY empid ASC) AS asct 
    FROM employee
)
SELECT * 
FROM first_last 
WHERE asct = 1 OR asct = 15;


-- # Approach 2:
-- First and last row in one query
(
    SELECT *
    FROM Employee
    ORDER BY EmpID ASC
    LIMIT 1
)
UNION
(
    SELECT *
    FROM Employee
    ORDER BY EmpID DESC
    LIMIT 1
);











